# Cấu hình Port chạy ứng dụng local
PORT=5000

# Môi trường chạy ứng dụng (development hoặc production)
NODE_ENV=development

# --- Cấu hình Kết nối MySQL Database ---
# Lựa chọn 1: Cấu hình thông số riêng lẻ (Thường dùng ở local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=todo_db

# Lựa chọn 2: Sử dụng một chuỗi kết nối duy nhất ( DATABASE_URL )
# Cực kỳ phổ biến và khuyên dùng khi deploy lên các dịch vụ Cloud như Render, Railway, Aiven
# Định dạng: mysql://username:password@host:port/database_name
DATABASE_URL=mysql://root:your_password@localhost:3306/todo_db
